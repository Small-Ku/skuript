	"license": "MIT",
	"devDependencies": {
		"@types/bun": "latest",
		"@types/yargs": "^17.0.33",
		"lightningcss-wasm": "^1.29.1",
		"rimraf": "^6.0.1",
		"sass": "^1.85.0",
		"type-fest": "^4.33.0",
		"winston": "^3.17.0",
		"yargs": "^17.7.2"
	},
	"peerDependencies": {
		"typescript": "^5.6.2"
	},
	"scripts": {
		"build": "bun build.ts",
