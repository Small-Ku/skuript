{
	"name": "skuript",
	"version": "1.0.2",
	"description": "A Greasemonkey/Tampermonkey/Violentmonkey Bun + TypeScript boilerplate",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Small-Ku/skuript.git"
	},
	"bugs": {
		"url": "https://github.com/Small-Ku/skuript/issues"
	},
	"homepage": "https://github.com/Small-Ku/skuript#readme",
